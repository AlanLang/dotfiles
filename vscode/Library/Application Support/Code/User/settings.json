{
    "workbench.colorTheme": "Ocean",
    "workbench.preferredDarkColorTheme": "Ocean",
    "workbench.preferredLightColorTheme": "Ocean",
    "workbench.productIconTheme": "icons-carbon",
    "workbench.iconTheme": "file-icons",
    "workbench.fontAliasing": "antialiased",
    "workbench.tree.enableStickyScroll": true,
    "editor.fontFamily": "'FiraCode Nerd Font Mono', 'Monaco Nerd Font', 'Menlo', 'DejaVu Sans Mono', 'Lucida Console', monospace",
    "editor.fontSize": 14,
    "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss06', 'zero'",
    "editor.accessibilitySupport": "off",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "smooth",
    "editor.find.addExtraSpaceOnTop": false,
    "editor.guides.bracketPairs": "active",
    "editor.inlineSuggest.enabled": true,
    "editor.lineNumbers": "relative",
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.mouseWheelZoom": false,
    "editor.tabSize": 2,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.stickyScroll.enabled": true,
    "editor.hover.sticky": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.tslint": "explicit",
        "source.fixAll.stylelint": "explicit",
        "source.fixAll.eslint": "explicit",
        "source.fixAll": "never",
        "source.organizeImports": "never"
    },
    "explorer.confirmDelete": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.suggestSelection": "recentlyUsed",
    "debug.showBreakpointsInOverviewRuler": true,
    "explorer.confirmDragAndDrop": false,
    "editor.smoothScrolling": true,
    "window.autoDetectColorScheme": true,
    "window.dialogStyle": "custom",
    "window.titleBarStyle": "custom",
    "workbench.editor.closeOnFileDelete": true,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.tabCloseButton": "left",
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.limit.value": 5,
    "workbench.list.smoothScrolling": true,
    "workbench.tree.expandMode": "singleClick",
    "workbench.tree.indent": 10,
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "extensions.ignoreRecommendations": true,
    "files.eol": "\n",
    "files.insertFinalNewline": false,
    "files.simpleDialog.enable": true,
    "files.autoGuessEncoding": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.untrackedChanges": "separate",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.fontWeight": "300",
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.fontFamily": "FiraCode Nerd Font",
    "scm.diffDecorationsGutterWidth": 2,
    "debug.onTaskErrors": "debugAnyway",
    "diffEditor.ignoreTrimWhitespace": false,
    "search.exclude": {
        "**/.git": true,
        "**/.github": true,
        "**/.nuxt": true,
        "**/.output": true,
        "**/.pnpm": true,
        "**/.vscode": true,
        "**/.yarn": true,
        "**/bower_components": true,
        "**/dist/**": true,
        "**/logs": true,
        "**/node_modules": true,
        "**/out/**": true,
        "**/package-lock.json": true,
        "**/pnpm-lock.yaml": true,
        "**/tmp": true,
        "**/yarn.lock": true
    },
    "[rust]": {
        "editor.formatOnSave": true
    },
    "gitlens.codeLens.enabled": false,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false,
        "yaml": true,
        "typescript": true
    },
    "typescript.preferences.importModuleSpecifier": "relative",
    "GitCommitPlugin.Templates": [
        {
            "templateContent": "<type>:<space><subject><space>#<footer>",
            "default": true,
            "templateName": "fr"
        }
    ],
    "gauge.recommendedSettings.options": "Apply & Reload",
    "files.exclude": {
        "**/.project": true,
        "**/.settings": true,
        "**/.classpath": true,
        "**/.factorypath": true,
        "node_modules/": true
    },
    "security.workspace.trust.untrustedFiles": "open",
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "html",
        "astro"
    ],
    "GitCommitPlugin.ShowEmoji": false,
    "cSpell.enabled": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "gitlens.advanced.messages": {
        "suppressLineUncommittedWarning": true
    },
    "editor.unicodeHighlight.allowedLocales": {
        "zh-hans": true
    },
    "editor.wordWrap": "on",
    "cSpell.userWords": [
        "alanlang",
        "antd",
        "bindgen",
        "Cmen",
        "craco",
        "draggable",
        "Dribbble",
        "glidejs",
        "Groupable",
        "linkding",
        "parms",
        "queryselector",
        "selecto",
        "sider",
        "snappable",
        "Submenu",
        "tanasuo",
        "Unmount"
    ],
    "files.autoSave": "off",
    "liveServer.settings.donotShowInfoMsg": true,
    "terminal.integrated.env.osx": {
        "FIG_NEW_SESSION": "1"
    },
    "rust-analyzer.inlayHints.typeHints.enable": false,
    "rust-analyzer.inlayHints.parameterHints.enable": false,
    "rust-analyzer.inlayHints.chainingHints.enable": false,
    "beancount.mainBeanFile": "main.bean",
    "prettier.documentSelectors": [
        "**/*.astro"
    ],
    "[astro]": {
        "editor.defaultFormatter": "astro-build.astro-vscode"
    },
    "git.openRepositoryInParentFolders": "never",
    "autocorrect.enable": false,
    "autocorrect.enableLint": true,
    "autocorrect.formatOnSave": true,
    "vim.leader": "<space>",
    "vim.autoSwitchInputMethod.enable": true,
    "vim.autoSwitchInputMethod.defaultIM": "com.apple.keylayout.ABC",
    "vim.autoSwitchInputMethod.obtainIMCmd": "/usr/local/bin/im-select",
    "vim.autoSwitchInputMethod.switchIMCmd": "/usr/local/bin/im-select {im}",
    "vim.useSystemClipboard": true,
    "vim.sneak": false,
    "vim.sneakUseIgnorecaseAndSmartcase": false,
    "vim.flash.enable": true,
    "vim.flash.ignorecase": true,
